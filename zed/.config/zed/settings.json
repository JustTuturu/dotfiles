// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// Note: keep secrets out of dotfiles. Add API keys locally after stowing.

{
  "language_models": {
    "openai_compatible": {
      "LocalHost": {
        "api_url": "http://localhost:20128/v1",
        "available_models": [
          {
            "name": "google/gemma-4-31b-it:free",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "debugger": {
    "dock": "bottom"
  },
  "scrollbar": {
    "selected_symbol": true,
    "show": "never",
    "cursors": true
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "sticky_scroll": true,
    "auto_reveal_entries": true,
    "starts_open": true,
    "auto_fold_dirs": true,
    "scrollbar": {
      "horizontal_scroll": false,
      "show": "never"
    },
    "folder_icons": true,
    "dock": "left"
  },
  "outline_panel": {
    "file_icons": true,
    "button": false,
    "dock": "right"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "git_panel": {
    "file_icons": false,
    "tree_view": false,
    "scrollbar": {
      "show": "never"
    },
    "button": true,
    "dock": "right"
  },
  "context_servers": {},
  "edit_predictions": {
    "mode": "eager",
    "open_ai_compatible_api": {
      "api_url": "https://opencode.ai/zen/go/v1",
      "model": "opencode-go/kimi-k2.5",
    },
    "ollama": {
      "max_output_tokens": 64,
    },
    "provider": "zed",
  },
  "disable_ai": false,
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "flexible": false,
    "font_family": "JetBrainsMono Nerd Font Mono",
    "line_height": {
      "custom": 1.1,
    },
  },
  "agent": {
    "default_profile": "write",
    "sidebar_side": "right",
    "dock": "right",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "enable_thinking": false,
    },
    "play_sound_when_agent_done": "always",
    "single_file_review": true,
    "enabled": true,
    "button": true,
    "favorite_models": [],
    "model_parameters": [],
  },
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },

  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "file_types": {
    "C++": ["c"],
    "Shell Script": ["conf", "rasi", "noctalia", "ghostty", "zsh","mustache"],
    "Dockerfile": ["Dockerfile*"],
    "TOML":[],
  },
}
