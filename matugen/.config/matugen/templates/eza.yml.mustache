colourful: true

filekinds:
  normal: {foreground: "{{colors.on_surface.default.hex}}"}
  directory: {foreground: "{{colors.primary.default.hex}}"}
  symlink: {foreground: "{{colors.secondary.default.hex}}"}
  pipe: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  block_device: {foreground: "{{colors.error.default.hex}}"}
  char_device: {foreground: "{{colors.error.default.hex}}"}
  socket: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  special: {foreground: "{{colors.primary.default.hex}}"}
  executable: {foreground: "{{colors.tertiary.default.hex}}"}
  mount_point: {foreground: "{{colors.secondary.default.hex}}"}

perms:
  user_read: {foreground: "{{colors.error.default.hex}}", is_bold: true}
  user_write: {foreground: "{{colors.primary_container.default.hex}}", is_bold: true}
  user_execute_file: {foreground: "{{colors.tertiary.default.hex}}", is_bold: true}
  user_execute_other: {foreground: "{{colors.tertiary.default.hex}}", is_bold: true}
  group_read: {foreground: "{{colors.error.default.hex}}"}
  group_write: {foreground: "{{colors.primary_container.default.hex}}"}
  group_execute: {foreground: "{{colors.tertiary.default.hex}}"}
  other_read: {foreground: "{{colors.error.default.hex}}"}
  other_write: {foreground: "{{colors.primary_container.default.hex}}"}
  other_execute: {foreground: "{{colors.tertiary.default.hex}}"}
  special_user_file: {foreground: "{{colors.primary.default.hex}}"}
  special_other: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  attribute: {foreground: "{{colors.outline.default.hex}}"}

size:
  major: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  minor: {foreground: "{{colors.secondary.default.hex}}"}
  number_byte: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  number_kilo: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  number_mega: {foreground: "{{colors.primary.default.hex}}"}
  number_giga: {foreground: "{{colors.primary.default.hex}}"}
  number_huge: {foreground: "{{colors.primary.default.hex}}"}
  unit_byte: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  unit_kilo: {foreground: "{{colors.secondary.default.hex}}"}
  unit_mega: {foreground: "{{colors.primary.default.hex}}"}
  unit_giga: {foreground: "{{colors.primary.default.hex}}"}
  unit_huge: {foreground: "{{colors.secondary.default.hex}}"}

users:
  user_you: {foreground: "{{colors.on_surface.default.hex}}"}
  user_root: {foreground: "{{colors.error.default.hex}}"}
  user_other: {foreground: "{{colors.error.default.hex}}"}
  group_yours: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  group_other: {foreground: "{{colors.outline.default.hex}}"}
  group_root: {foreground: "{{colors.error.default.hex}}"}

links:
  normal: {foreground: "{{colors.secondary.default.hex}}"}
  multi_link_file: {foreground: "{{colors.secondary.default.hex}}"}

git:
  new: {foreground: "{{colors.tertiary.default.hex}}"}
  modified: {foreground: "{{colors.primary_container.default.hex}}"}
  deleted: {foreground: "{{colors.error.default.hex}}"}
  renamed: {foreground: "{{colors.secondary.default.hex}}"}
  typechange: {foreground: "{{colors.primary.default.hex}}"}
  ignored: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  conflicted: {foreground: "{{colors.error.default.hex}}"}

git_repo:
  branch_main: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  branch_other: {foreground: "{{colors.primary.default.hex}}"}
  git_clean: {foreground: "{{colors.tertiary.default.hex}}"}
  git_dirty: {foreground: "{{colors.error.default.hex}}"}

security_context:
  colon: {foreground: "{{colors.outline.default.hex}}"}
  user: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  role: {foreground: "{{colors.primary.default.hex}}"}
  typ: {foreground: "{{colors.outline.default.hex}}"}
  range: {foreground: "{{colors.primary.default.hex}}"}

file_type:
  image: {foreground: "{{colors.primary_container.default.hex}}"}
  video: {foreground: "{{colors.error.default.hex}}"}
  music: {foreground: "{{colors.tertiary.default.hex}}"}
  lossless: {foreground: "{{colors.secondary.default.hex}}"}
  crypto: {foreground: "{{colors.on_surface_variant.default.hex}}"}
  document: {foreground: "{{colors.on_surface.default.hex}}"}
  compressed: {foreground: "{{colors.primary.default.hex}}"}
  temp: {foreground: "{{colors.error.default.hex}}"}
  compiled: {foreground: "{{colors.secondary.default.hex}}"}
  source: {foreground: "{{colors.secondary.default.hex}}"}

punctuation: {foreground: "{{colors.outline.default.hex}}"}
date: {foreground: "{{colors.primary_container.default.hex}}"}
inode: {foreground: "{{colors.on_surface_variant.default.hex}}"}
blocks: {foreground: "{{colors.outline.default.hex}}"}
header: {foreground: "{{colors.on_surface.default.hex}}"}
octal: {foreground: "{{colors.secondary.default.hex}}"}
flags: {foreground: "{{colors.primary.default.hex}}"}

symlink_path: {foreground: "{{colors.secondary.default.hex}}"}
control_char: {foreground: "{{colors.secondary.default.hex}}"}
broken_symlink: {foreground: "{{colors.error.default.hex}}"}
broken_path_overlay: {foreground: "{{colors.outline.default.hex}}"}
