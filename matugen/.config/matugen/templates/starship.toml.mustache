# Matugen-generated Starship config — DO NOT EDIT

"$schema" = 'https://starship.rs/config-schema.json'
add_newline = true
scan_timeout = 100
command_timeout = 1000

format = """
$directory\
$git_branch\
$git_status\
$nodejs\
$python\
$rust\
$docker_context\
$character"""

[directory]
truncation_length = 3
truncation_symbol = "…/"
style = "bold fg:{{colors.on_surface.default.hex}}"

[character]
success_symbol = "[➜](bold fg:{{colors.tertiary.default.hex}})"
error_symbol = "[✗](bold fg:{{colors.error.default.hex}})"

[git_branch]
symbol = " "
style = "bold fg:{{colors.primary.default.hex}}"

[git_status]
style = "fg:{{colors.on_surface_variant.default.hex}}"
format = '([\[$all_status$ahead_behind\]]($style) )'

[package]
disabled = true

[nodejs]
disabled = false
symbol = "󰎙 "
style = "fg:{{colors.inverse_surface.default.hex}}"
format = "via [node $version](bold fg:{{colors.inverse_surface.default.hex}}) "

[python]
disabled = false
symbol = "󰌠 "
style = "fg:{{colors.primary_container.default.hex}}"

[rust]
disabled = false
symbol = "󱘗 "
style = "fg:{{colors.secondary.default.hex}}"

[ruby]
disabled = true

[java]
disabled = true
