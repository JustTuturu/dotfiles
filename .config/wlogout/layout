{
    "layer": "overlay",
    "position": "center",
    "margin": 20,
    "items_per_line": 4,
    "spacing": 15,
    "buttons": [
        {
            "label": "Lock",
            "action": "hyprlock",
            "image": "/usr/share/wlogout/icons/lock.png"
        },
        {
            "label": "Logout",
            "action": "hyprctl dispatch exit",
            "image": "/usr/share/wlogout/icons/logout.png"
        },
        {
            "label": "Suspend",
            "action": "systemctl suspend",
            "image": "/usr/share/wlogout/icons/suspend.png"
        },
        {
            "label": "Reboot",
            "action": "systemctl reboot",
            "image": "/usr/share/wlogout/icons/reboot.png"
        },
        {
            "label": "Shutdown",
            "action": "systemctl poweroff",
            "image": "/usr/share/wlogout/icons/shutdown.png"
        }
    ]
}
